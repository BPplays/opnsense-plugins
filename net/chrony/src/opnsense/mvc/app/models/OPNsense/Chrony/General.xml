<model>
    <mount>//OPNsense/chrony/general</mount>
    <description>Chrony configuration</description>
    <version>0.0.3</version>
    <items>
        <enabled type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </enabled>
        <port type="PortField">
            <Default>323</Default>
            <Required>Y</Required>
        </port>
        <ntsclient type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </ntsclient>
        <ntsnocert type="BooleanField">
            <Default>0</Default>
            <Required>Y</Required>
        </ntsnocert>
        <allowednetworks type="NetworkField">
            <Required>N</Required>
            <FieldSeparator>,</FieldSeparator>
            <AsList>Y</AsList>
        </allowednetworks>
    </items>
</model>
